<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="10dp">

    <TextView
        android:id="@+id/widget_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="Music Player"
        android:textColor="@android:color/white"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/widget_artist"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="Touch to play"
        android:textColor="#88FFFFFF"
        android:textSize="14sp" />

    <!-- Minimal controls using standard system resources only -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/widget_prev_btn"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_media_previous" />

        <ImageView
            android:id="@+id/widget_play_pause_btn"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="10dp"
            android:src="@android:drawable/ic_media_play" />

        <ImageView
            android:id="@+id/widget_next_btn"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_media_next" />
    </LinearLayout>

    <!-- Hidden compatibility fields - MUST exist but use simplest possible views -->
    <ImageView android:id="@+id/widget_artwork" android:layout_width="1dp" android:layout_height="1dp" android:visibility="gone" />
    <ImageView android:id="@+id/widget_background_art" android:layout_width="1dp" android:layout_height="1dp" android:visibility="gone" />
    <ProgressBar android:id="@+id/widget_progress" android:layout_width="1dp" android:layout_height="1dp" android:visibility="gone" />
    <TextView android:id="@+id/widget_current_time" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
    <TextView android:id="@+id/widget_total_time" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
    <ImageButton android:id="@+id/widget_shuffle_btn" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
    <ImageButton android:id="@+id/widget_repeat_btn" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />

</LinearLayout>
